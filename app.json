{
  "expo": {
    "name": "smilescraft-mobile",
    "slug": "smilescraft-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/brand/icon-ios.png",
    "scheme": "smilescraftmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/brand/icon-android.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.smilescraft.mobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/brand/icon-ios.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/brand/smilecraft-wordmark.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4b74c6f1-2e77-42d2-867a-6ddba954d764"
      }
    }
  }
}
