{
  "cli": { "version": ">= 13.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_URL": "https://www.smilescraft.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "APP_ENV": "staging",
        "EXPO_PUBLIC_API_URL": "https://www.smilescraft.com"
      }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://www.smilescraft.com"
      }
    }
  }
}
